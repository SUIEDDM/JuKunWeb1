{
  "apps": [
    {
      "name": "jukun-server",
      "script": "src/app.js",
      "cwd": "./server",
      "instances": 1,
      "exec_mode": "fork",
      "watch": false,
      "ignore_watch": ["node_modules", "uploads"],
      "max_memory_restart": "500M",
      "env": {
        "NODE_ENV": "production",
        "PORT": 3001
      },
      "env_development": {
        "NODE_ENV": "development"
      },
      "error_file": "./logs/error.log",
      "out_file": "./logs/out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true,
      "autorestart": true,
      "max_restarts": 10,
      "restart_delay": 1000
    }
  ]
}
